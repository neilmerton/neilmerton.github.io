---
export interface Props {
  page: any;
  baseUrl?: string;
}

const { page, baseUrl = "/blog" } = Astro.props;

const totalPages = page.lastPage;
const validPage = page.currentPage;

const buildUrl = (pageNum: number) => {
  if (pageNum === 1) return baseUrl;
  return `${baseUrl}/${pageNum}`;
};
---

<nav class="pagination" aria-label="Pagination">
  {
    page.url.prev ? (
      <a
        href={page.url.prev}
        class="pagination__prev"
        aria-label="Previous page"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6" />
        </svg>
        Previous
      </a>
    ) : (
      <span class="pagination__prev" aria-disabled="true">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6" />
        </svg>
        Previous
      </span>
    )
  }

  <ul class="pagination__list" role="list">
    {
      Array.from({ length: totalPages }).map((_, i) => {
        const pageNum = i + 1;
        return (
          <li>
            <a
              href={buildUrl(pageNum)}
              class={`pagination__page ${pageNum === validPage ? "pagination__page--active" : ""}`}
              aria-current={pageNum === validPage ? "page" : undefined}
              aria-label={`Page ${pageNum}`}
            >
              {pageNum}
            </a>
          </li>
        );
      })
    }
  </ul>

  {
    page.url.next ? (
      <a href={page.url.next} class="pagination__next" aria-label="Next page">
        Next
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </a>
    ) : (
      <span class="pagination__next" aria-disabled="true">
        Next
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </span>
    )
  }
</nav>

<style>
  .pagination {
    border-block-start: 1px solid var(--color-border-light);
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin-block-start: var(--space-12);
    padding-block-start: var(--space-8);
  }

  .pagination__list {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pagination__prev,
  .pagination__next {
    align-items: center;
    color: var(--color-text);
    display: inline-flex;
    font-weight: 500;
    gap: var(--space-2);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pagination__prev:hover,
  .pagination__next:hover {
    color: var(--color-accent);
  }

  .pagination__prev[aria-disabled="true"],
  .pagination__next[aria-disabled="true"] {
    color: var(--color-text-muted);
    pointer-events: none;
    opacity: 0.5;
  }

  .pagination__prev svg,
  .pagination__next svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  :global(.pagination__page) {
    align-items: center;
    border: 1px solid var(--color-accent);
    border-radius: calc(var(--radius-md) * 0.75);
    color: var(--color-text);
    display: inline-flex;
    font-weight: 500;
    height: 2.5rem;
    justify-content: center;
    min-width: 2.5rem;
    padding: 0 var(--space-2);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  :global(.pagination__page:hover) {
    background-color: var(--color-bg-alt);
    color: var(--color-accent);
  }

  :global(.pagination__page--active) {
    background-color: var(--color-accent-bg);
    color: var(--color-accent-text);
  }

  :global(.pagination__page--active:hover) {
    background-color: var(--color-accent-hover);
  }

  @media (max-width: 640px) {
    .pagination {
      flex-direction: column;
      gap: var(--space-6);
    }

    .pagination__list {
      order: -1;
    }
  }
</style>
