---

<nav class="pagination animate-in animate-in--delay-3" aria-label="Pagination" id="blog-pagination" style="display: none;">
  <a href="#" class="pagination__prev" id="pagination-prev" aria-label="Previous page">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
    Previous
  </a>
  <ul class="pagination__list" id="pagination-list" role="list">
    <!-- Page numbers injected here by JS -->
  </ul>
  <a href="#" class="pagination__next" id="pagination-next" aria-label="Next page">
    Next
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </a>
</nav>

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-block-start: var(--space-12);
    padding-block-start: var(--space-8);
    border-block-start: 1px solid var(--color-border-light);
  }

  .pagination__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pagination__prev,
  .pagination__next {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pagination__prev:hover,
  .pagination__next:hover {
    color: var(--color-accent);
  }

  .pagination__prev[aria-disabled="true"],
  .pagination__next[aria-disabled="true"] {
    color: var(--color-text-muted);
    pointer-events: none;
    opacity: 0.5;
  }

  .pagination__prev svg,
  .pagination__next svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  :global(.pagination__page) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 var(--space-2);
    border-radius: calc(var(--radius-md) * 0.75);
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  :global(.pagination__page:hover) {
    background-color: var(--color-bg-alt);
    color: var(--color-accent);
  }

  :global(.pagination__page--active) {
    background-color: var(--color-accent-bg);
    color: #ffffff !important;
  }

  :global(.pagination__page--active:hover) {
    background-color: var(--color-accent-hover);
  }

  @media (max-width: 640px) {
    .pagination {
      flex-direction: column;
      gap: var(--space-6);
    }
    
    .pagination__list {
      order: -1;
    }
  }
</style>
