---
import { Image } from "astro:assets";

interface Props {
  item: {
    id: string;
    data: {
      cover: any;
      description: string;
      status: "live" | "archived" | "upcoming";
      tags: string[];
      title: string;
    };
  };
}

const { item } = Astro.props as Props;
---

<li class="portfolio-list__item">
  <a href={`/portfolio/${item.id}`} class="portfolio-list__link">
    <Image
      alt={`${item.data.title} screenshot`}
      src={item.data.cover}
      height={495}
      quality="high"
      width={704}
    />
  </a>
  <div class="portfolio-list__meta">
    <h2>{item.data.title}</h2>
    <p class="text-xs">{item.data.description}</p>
  </div>
</li>

<style>
  .portfolio-list__item {
    border-block-end: 1px solid var(--color-border-light);
    padding-block: var(--space-8);

    &:first-child {
      padding-block-start: 0;
    }

    &:last-child {
      border-block-end: none;
    }
  }

  .portfolio-list__link {
    display: block;
    text-decoration: none;
  }

  .portfolio-list__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-block-start: var(--space-6);
  }
</style>
