---
interface Props {
  container?: boolean;
  description: string;
  leading: string;
  title: string;
}

const { container, description, leading, title } = Astro.props as Props;
---

<section class:list={["hero", { container }]}>
  {
    Astro.slots.has("nav") && (
      <div class="hero__nav">
        <slot name="nav" />
      </div>
    )
  }
  <p class="hero__eyebrow">{leading}</p>
  <h1 class="hero__name">{title}</h1>
  <p class="hero__tagline">{description}</p>
  {
    Astro.slots.has("actions") && (
      <div class="hero__actions">
        <slot name="actions" />
      </div>
    )
  }
</section>

<style>
  .hero {
    border-block-end: 1px solid var(--color-border-light);
    margin-block-end: var(--space-10);
    padding-block: var(--space-12) var(--space-10);

    &.container {
      padding-block-end: var(--space-24);
      padding-block-start: clamp(var(--space-20), 12vw, var(--space-32));
    }
  }

  .hero__eyebrow {
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    margin-block-end: var(--space-4);
    text-transform: uppercase;
  }

  .hero__name {
    color: var(--color-text);
    font-size: clamp(var(--text-4xl), 8vw, 5rem);
    margin-block-end: var(--space-6);
  }

  .hero__tagline {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    max-width: 50ch;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-direction: column;
    margin-block-start: var(--space-10);

    @media (min-width: 640px) {
      flex-direction: row;
    }
  }
</style>
