---
import ConcertListItem from "@components/ConcertListItem.astro";
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";

const allConcerts = await getCollection("concerts");

// Group by year (newest year first, and concerts within each year sorted newest first)
const concertsByYear = allConcerts.reduce<Record<string, typeof allConcerts>>(
  (acc, concert) => {
    const year = concert.data.date.getFullYear().toString();

    if (!acc[year]) {
      acc[year] = [];
    }

    acc[year].push(concert);

    // Sort concerts in this year by date (newest first)
    acc[year].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

    return acc;
  },
  {},
);

// Artists list including counts (including support acts), sorted by most times seen (excluding future dates), then alphabetically
const artistCounts: Record<string, number> = {};
// Venues list including counts (sorted by most visited, excluding future dates), then alphabetically
const venueCounts: Record<string, number> = {};

allConcerts.forEach((concert) => {
  const artists = [concert.data.artist, ...(concert.data.support || [])];
  const venue = concert.data.venue;

  artists.forEach((artist) => {
    const haveBeenTo = concert.data.date <= new Date();

    if (!artistCounts[artist] && haveBeenTo) {
      artistCounts[artist] = 0;
    }

    if (!venueCounts[venue] && haveBeenTo) {
      venueCounts[venue] = 0;
    }

    // Only count concerts that have already happened
    if (haveBeenTo) {
      artistCounts[artist]++;
      venueCounts[venue]++;
    }
  });
});

const artists = Object.entries(artistCounts)
  .map(([artist, count]) => ({ artist, count }))
  .sort((a, b) => b.count - a.count || a.artist.localeCompare(b.artist));
---

<Layout
  title="Concerts"
  description="A log of concerts I've attended, with details and some notes."
>
  <div class="container">
    <header class="page-hero animate-in">
      <span class="page-hero__eyebrow">Music</span>
      <h1 class="page-hero__title">Concerts</h1>
      <p class="page-hero__subtitle">
        A log of concerts I've attended, with details and some notes.
        {
          allConcerts.length === 0
            ? " No concerts yet!"
            : ` ${allConcerts.length} concerts and counting!`
        }
      </p>
    </header>

    {
      artists.length > 0 && (
        <section class="concert-artists animate-in">
          <h2 class="concert-artists__title">
            Most Seen Artists
            <span class="concert-artists__count">{artists.length}</span>
          </h2>
          <ul class="concert-artists__list">
            {artists.map(({ artist, count }) => (
              <li class="concert-artists__item">
                {artist}
                <span
                  class="concert-artists__count"
                  aria-label={`Seen ${artist} ${count} times`}
                  data-count
                >
                  {count}
                </span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      Object.keys(venueCounts).length > 0 && (
        <section class="concert-venues animate-in">
          <h2 class="concert-venues__title">
            Most Visited Venues
            <span class="concert-venues__count">
              {Object.keys(venueCounts).length}
            </span>
          </h2>
          <ul class="concert-venues__list">
            {Object.entries(venueCounts)
              .map(([venue, count]) => ({ venue, count }))
              .sort(
                (a, b) => b.count - a.count || a.venue.localeCompare(b.venue),
              )
              .map(({ venue, count }) => (
                <li class="concert-venues__item">
                  {venue}
                  <span
                    class="concert-venues__count"
                    aria-label={`Visited ${venue} ${count} times`}
                    data-count
                  >
                    {count}
                  </span>
                </li>
              ))}
          </ul>
        </section>
      )
    }

    {
      Object.entries(concertsByYear)
        .sort(([yearA], [yearB]) => parseInt(yearB) - parseInt(yearA))
        .map(([year, concerts]) => (
          <section class="concert-year">
            <h2 class="concert-year__title">
              {year}
              <span
                class="concert-year__count"
                aria-label={`${concerts.length} concerts in ${year}`}
                data-count
              >
                {concerts.length}
              </span>
            </h2>
            <div class="concert-list">
              {concerts.map((concert) => (
                <ConcertListItem concert={concert} />
              ))}
            </div>
          </section>
        ))
    }
  </div>
</Layout>

<style>
  .concert-artists,
  .concert-venues {
    margin-block-end: var(--space-12);
  }

  .concert-artists__title,
  .concert-venues__title {
    align-items: center;
    color: var(--color-text-muted);
    display: flex;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    gap: var(--space-3);
    margin-block-end: var(--space-6);
  }

  .concert-artists__list,
  .concert-venues__list {
    column-gap: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
    row-gap: var(--space-3);
  }

  .concert-artists__item,
  .concert-venues__item {
    align-items: center;
    display: flex;
    gap: var(--space-2);
  }

  .concert-artists__count,
  .concert-venues__count {
    align-items: center;
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-pill);
    color: var(--color-text-subtle);
    display: inline-flex;
    font-size: var(--text-xs);
    height: 22px;
    justify-content: center;
    width: 22px;
  }

  .concert-year {
    margin-bottom: var(--space-12);
  }

  .concert-year__title {
    align-items: center;
    color: var(--color-text-muted);
    display: flex;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    gap: var(--space-3);
    margin-block-end: var(--space-6);
  }

  .concert-list {
    display: grid;
    gap: var(--space-8);
  }

  .concert-year__count {
    align-items: center;
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-pill);
    color: var(--color-text-subtle);
    display: inline-flex;
    font-size: var(--text-xs);
    height: 22px;
    justify-content: center;
    width: 22px;
  }
</style>
