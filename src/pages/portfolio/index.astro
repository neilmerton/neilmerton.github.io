---
import PageHero from "@components/PageHero.astro";
import PortfolioListItem from "@components/PortfolioListItem.astro";
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";

const portfolioItems = await getCollection("portfolio");

const sortedPortfolioItems = portfolioItems.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout
  title="Portfolio"
  description="A showcase of projects I've worked on, with descriptions and tags."
>
  <div class="container">
    <PageHero
      description="A selection of projects I've worked on, with descriptions and tags. Some are live, some are archived, and some are upcoming."
      leading="Examples"
      title="Portfolio"
    />

    <div class="portfolio-section">
      <ol class="portfolio-list" role="list">
        {sortedPortfolioItems.map((item) => <PortfolioListItem item={item} />)}
      </ol>
    </div>
  </div>
</Layout>

<style>
  .portfolio-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .portfolio-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
