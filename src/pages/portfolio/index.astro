---
import PortfolioListItem from "@components/PortfolioListItem.astro";
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";

const portfolioItems = await getCollection("portfolio");

const sortedPortfolioItems = portfolioItems.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout
  title="Portfolio"
  description="A showcase of projects I've worked on, with descriptions and tags."
>
  <div class="container">
    <header class="page-hero animate-in">
      <span class="page-hero__eyebrow">Projects</span>
      <h1 class="page-hero__title">Portfolio</h1>
      <p class="page-hero__subtitle">
        A selection of projects I've worked on, with descriptions and tags.
        {
          portfolioItems.length > 0 && (
            <> Some are live, some are archived, and some are upcoming.</>
          )
        }
      </p>
    </header>

    <div class="portfolio-section animate-in animate-in--delay-2">
      <ol class="portfolio-list" role="list">
        {sortedPortfolioItems.map((item) => <PortfolioListItem item={item} />)}
      </ol>
    </div>
  </div>
</Layout>

<style>
  .portfolio-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .portfolio-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
