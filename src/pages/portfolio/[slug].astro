---
import Layout from "@layouts/Layout.astro";
import { getPortfolioImages } from "@utils/index";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const portfolioItems = await getCollection("portfolio");

  const paths = Object.values(portfolioItems).map((item) => {
    return {
      params: {
        slug: item.id,
      },
      props: {
        item,
      },
    };
  });

  return paths;
}

interface Props {
  item: CollectionEntry<"portfolio">;
}

const { item } = Astro.props as Props;

if (!item) {
  return Astro.redirect("/404");
}
const images = await getPortfolioImages(item.id);

const { Content } = await render(item);
---

<Layout title={item.data.title} description={item.data.description}>
  <article
    class="container portfolio-page"
    itemscope
    itemtype="https://schema.org/CreativeWork"
  >
    <header class="portfolio-header">
      <nav class="portfolio-breadcrumb" aria-label="Breadcrumb">
        <a href="/portfolio">← Portfolio</a>
      </nav>

      <h1 class="portfolio-header__title" itemprop="headline">
        {item.data.title}
      </h1>

      <p class="portfolio-header__description" itemprop="description">
        {item.data.description}
      </p>

      {
        item.data.tags.length > 0 && (
          <ul
            class="portfolio-header__tags"
            role="list"
            aria-label="Portfolio tags"
          >
            {item.data.tags.map((tag) => (
              <li>
                <span class="tag">{tag}</span>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      item.data.link && (
        <section class="portfolio-link">
          <p>
            <a href={item.data.link} target="_blank" rel="noopener noreferrer">
              {item.data.linkLabel
                ? `${item.data.linkLabel} →`
                : "Visit website →"}
            </a>
          </p>
        </section>
      )
    }

    {
      (item.data.codePenEmbedLabel && item.data.codePenEmbedPen) && (
        <p class="codepen" data-height={item.data.codePenEmbedHeight ?? '400'} data-pen-title={item.data.codePenEmbedLabel} data-slug-hash={item.data.codePenEmbedPen} data-user="neilmerton" style={`height: ${item.data.codePenEmbedHeight ?? 400}px; box-sizing: border-box; display: flex; align-items: center; justify-content: center; border: 2px solid; margin: 1em 0; padding: 1em;`}>
          <span>See the Pen <a href={`https://codepen.io/neilmerton/pen/${item.data.codePenEmbedPen}`}>
          {item.data.codePenEmbedLabel}</a> by Neil Merton (<a href="https://codepen.io/neilmerton">@neilmerton</a>)
          on <a href="https://codepen.io">CodePen</a>.</span>
        </p>
        <script async is:inline src="https://public.codepenassets.com/embed/index.js"></script>
      )
    }

    {
      (!item.data.codePenEmbedPen) && (
        <div class="portfolio-images">
          {
            images.map((img) => (
              <Image
                alt={`${item.data.title} screenshot`}
                src={img}
                quality="high"
                width={704}
              />
            ))
          }
        </div>
      )
    }


    <div class="portfolio-body prose" itemprop="workBody">
      <Content />
    </div>

    <footer class="portfolio-footer">
      <hr />
      <a href="/portfolio" class="portfolio-footer__back">← Back to portfolio</a
      >
    </footer>
  </article>
</Layout>

<style>
  .portfolio-breadcrumb {
    margin-block-end: var(--space-8);
  }

  .portfolio-breadcrumb a {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    transition: color var(--transition-fast);

    &:hover {
      color: var(--color-accent);
    }
  }

  .portfolio-header {
    border-block-end: 1px solid var(--color-border-light);
    margin-block-end: var(--space-12);
    padding-block-end: var(--space-10);
    padding-block-start: var(--space-16);
  }

  .portfolio-header__title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    margin-block-end: var(--space-5);
    max-width: 22ch;
  }

  .portfolio-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-5) 0;
    padding: 0;
  }

  .portfolio-link {
    border-block-end: 1px solid var(--color-border-light);
    margin-block-end: var(--space-12);
    padding-block-end: var(--space-10);
  }

  .portfolio-images {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    margin-block-end: var(--space-12);
  }

  .portfolio-body {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    padding-block-end: var(--space-12);
  }

  .portfolio-footer hr {
    margin-block-end: var(--space-8);
  }

  .portfolio-footer__back {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    transition: color var(--transition-fast);

    &:hover {
      color: var(--color-accent);
    }
  }
</style>
