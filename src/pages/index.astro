---
import HomePostListItem from "@components/HomePostListItem.astro";
import PageHero from "@components/PageHero.astro";
import RandomSnippet from "@components/RandomSnippet.astro";
import { siteConfig } from "@data/index";
import Layout from "@layouts/Layout.astro";
import { isPublished, sortByDateDesc } from "@utils/index";
import { getCollection } from "astro:content";

// Fetch latest blog posts for the home page preview
const allPosts = (await getCollection("blog", isPublished)).sort(
  sortByDateDesc,
);
const latestPosts = allPosts.slice(0, 3);
---

<Layout title={siteConfig.title} description={siteConfig.description}>
  <PageHero
    container
    description={siteConfig.description}
    leading="Frontend Developer"
    title={siteConfig.name}
  >
    <Fragment slot="actions">
      <a href="/about" class="btn btn--primary">About me</a>
      <a href="/experience" class="btn btn--secondary">Experience</a>
      <a href="/portfolio" class="btn btn--secondary">Portfolio</a>
    </Fragment>
  </PageHero>

  {
    latestPosts.length > 0 && (
      <section class="home-section container">
        <header class="home-section__header">
          <h2 class="home-section__title">Recent Writing</h2>
          <a href="/blog" class="home-section__more">
            All posts →
          </a>
        </header>

        <ol class="post-list" role="list">
          {latestPosts.map((post) => (
            <HomePostListItem post={post} />
          ))}
        </ol>
      </section>
    )
  }

  <section class="home-section container">
    <header class="home-section__header">
      <h2 class="home-section__title">Did you know?</h2>
    </header>
    <RandomSnippet />
  </section>
</Layout>

<style>
  .home-section {
    padding-block: var(--space-16);
  }

  .home-section + .home-section {
    border-block-start: 1px solid var(--color-border-light);
  }

  .home-section__header {
    align-items: baseline;
    display: flex;
    gap: var(--space-4);
    justify-content: space-between;
    margin-block-end: var(--space-8);
  }

  .home-section__title {
    color: var(--color-text);
    font-size: var(--text-xl);
  }

  .home-section__more {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-decoration: none;
    white-space: nowrap;

    &:hover {
      color: var(--color-accent);
    }
  }

  .post-list {
    container: home-post-list / inline-size;
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
